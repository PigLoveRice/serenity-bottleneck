# .env.example — 配置模板

# Hermes LLM API
HERMES_API_BASE=http://127.0.0.1:8642/v1
HERMES_MODEL=deepseek-v4-pro
HERMES_API_KEY=your-hermes-api-key

# Anspire Search
ANSPIRE_API_KEYS=your-anspire-key

# FinanceMCP
FINANCEMCP_URL=https://finvestai.top/mcp
FINANCEMCP_TOKEN=your-token

# 飞书（可选）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
